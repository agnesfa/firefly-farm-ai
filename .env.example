# farmOS connection — copy this file to .env and fill in your credentials
FARMOS_URL=https://margregen.farmos.net
FARMOS_CLIENT_ID=farm
FARMOS_USERNAME=your_username
FARMOS_PASSWORD=your_password
FARMOS_SCOPE=farm_manager

# Field observation endpoint (Google Apps Script deployment URL)
OBSERVE_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
